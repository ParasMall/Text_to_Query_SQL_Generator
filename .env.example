# ─────────────────────────────────────────────────────────────────────────────
# DataCraft AI — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Provider Keys (at least one is required) ───────────────────────────────

# Google Gemini — get key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fast open-source models) — get key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenRouter (free model fallback) — get key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here


# ── Clerk Authentication ───────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys

# Secret key  (server-side only — never expose to the browser)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Publishable key (safe for browser)
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Vite exposes this to the frontend (must match CLERK_PUBLISHABLE_KEY)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Proxy URL — leave blank for local development; set in production only
VITE_CLERK_PROXY_URL=


# ── Frontend (Vite) — local dev values ────────────────────────────────────────
# Port for the React app (can be any free port)
PORT=5173

# Base path — use "/" for running at root locally
BASE_PATH=/


# ── Python API Server ─────────────────────────────────────────────────────────
# Port for the FastAPI/uvicorn server (8000 recommended for Windows)
API_PORT=8000
